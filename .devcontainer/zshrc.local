# devContainer 用 ~/.zshrc.local（postCreate.sh が配置）。
# .zshrc の末尾から source される。マシン固有の末尾処理をここに置く。

# mise / Claude Code は ~/.local/bin に入るので PATH を通す
export PATH="${HOME}/.local/bin:${PATH}"

# mise 有効化（言語/ツールのバージョン管理）
if [ -x "${HOME}/.local/bin/mise" ]; then
  eval "$("${HOME}/.local/bin/mise" activate zsh)"
fi

# syntax-highlighting は必ず最後（ZLE ウィジェットを触る処理より後）。
for d in /usr/share /usr/local/share; do
  f="$d/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
  [ -f "$f" ] && source "$f" && break
done
